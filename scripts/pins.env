# Upstream repository pins — single source of truth for reproducible clones.
# The sandbox never vendors upstream source; scripts/setup.sh clones these into
# .upstream/<project> at the exact commit so builds are deterministic.

# eShopOnWeb — no release tags upstream, so we pin the main branch HEAD at recon time.
ESHOP_REPO=https://github.com/NimblePros/eShopOnWeb.git
ESHOP_REF=5ad05cbe515f1c7e29b7bdfe373a9e49057bbb84   # main @ 2026-06-14

# Medplum — pinned to the latest stable release tag at recon time.
MEDPLUM_REPO=https://github.com/medplum/medplum.git
MEDPLUM_REF=v5.1.9                                    # 0b9a26b915d9404983f74754fdc68aef7f717297
